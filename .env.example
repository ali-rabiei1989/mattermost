# Copy this file to .env and adjust values
# cp .env.example .env

# Domain (used in Nginx server_name and Mattermost SiteURL)
MM_DOMAIN=chat.example.com

# DB (choose a strong password; if it contains special URL chars, URL-encode it in MM_SQL_DATASOURCE)
POSTGRES_DB=mattermost
POSTGRES_USER=mmpg
POSTGRES_PASSWORD=CHANGE_ME

# Mattermost
MM_SQL_DRIVER_NAME=postgres
MM_SQL_DATASOURCE=postgres://mmpg:CHANGE_ME@db:5432/mattermost?sslmode=disable&connect_timeout=10

# Email (optional)
MM_EMAILSETTINGS_FEEDBACKEMAIL=chat@example.com
MM_EMAILSETTINGS_REPLYTOADDRESS=noreply@example.com

# For initial setup (recommended)
MM_SERVICESETTINGS_SITEURL=https://chat.example.com

# Timezone
TZ=Asia/Tehran
